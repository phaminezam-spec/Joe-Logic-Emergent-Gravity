import numpy as np
from scipy.spatial import cKDTree

class JoeLogicMultiverse:
    def __init__(self, n_nodes=10000):
        # 1. INITIALIZE THE BULK (10,000 Nodes)
        self.pos = np.random.rand(n_nodes, 3)
        self.freqs = np.random.choice([50.0, 100.0], n_nodes) # Alpha & Delta
        self.layers = np.where(self.freqs == 50.0, 'Alpha', 'Delta')
        self.temps = np.zeros(n_nodes)
        self.h_z = 0.001 # Hubble Expansion Factor

    def step(self, r_connect=0.08, k_elastic=0.02):
        # 2. SPATIAL PARTITIONING (O(N log N))
        tree = cKDTree(self.pos)
        pairs = np.array(list(tree.query_pairs(r_connect)))
        
        if len(pairs) == 0: return self.pos
        
        i, j = pairs[:, 0], pairs[:, 1]
        diff = self.pos[j] - self.pos[i]
        dist = np.linalg.norm(diff, axis=1, keepdims=True) + 1e-7
        
        # 3. VECTORIZED RESONANCE (The Pull)
        # Calculate 1:2:3 Alignment (Resonance)
        res = 1.0 - np.abs(self.freqs[i] - self.freqs[j]) / (self.freqs[i] + self.freqs[j])
        res = res.reshape(-1, 1)
        
        # 4. ENTROPY PRESSURE (The Push)
        # Heat (Landauer Cost) pushes nodes away to form Voids
        temp_diff = (self.temps[j] - self.temps[i]).reshape(-1, 1)
        pressure_force = (diff / dist) * temp_diff * 0.05
        
        # 5. APPLY FORCES (The Spandex)
        forces = np.zeros_like(self.pos)
        # Resonance creates tension/attraction
        pull_mask = (self.layers[i] == self.layers[j]) | (res.flatten() > 0.85)
        strength = k_elastic * res[pull_mask]
        f_pull = (diff[pull_mask] / dist[pull_mask]) * (dist[pull_mask] * strength)
        
        np.add.at(forces, i[pull_mask], f_pull)
        np.add.at(forces, j[pull_mask], -f_pull)
        np.add.at(forces, i, -pressure_force) # Entropy Push
        
        # 6. HUBBLE EXPANSION & COOLING
        self.pos *= (1 + self.h_z)
        self.pos += forces
        self.temps *= 0.98 # Thermodynamic Decay
        
        return self.pos

    def trigger_epsilon_bounce(self):
        """Injects the 150Hz Fibonacci Harmonic (Gen-3)."""
        # Collapse nodes that hit critical proximity
        tree = cKDTree(self.pos)
        pairs = np.array(list(tree.query_pairs(0.02)))
        
        for i, j in pairs:
            if self.layers[i] != self.layers[j]:
                # Release Landauer Heat Pulse
                self.temps[i] += 1.0 
                # Graduate to Epsilon (The 5th Harmonic)
                if np.random.rand() > 0.95:
                    self.freqs[i] = 150.0
                    self.layers[i] = 'Epsilon'

# INITIALIZE THE BIG BANG
multiverse = JoeLogicMultiverse(10000)

print("Starting 10,000-node Multiverse Engine...")
for frame in range(200):
    multiverse.step()
    multiverse.trigger_epsilon_bounce()
    
    if frame == 50:
        print("Frame 50: Great Walls and Voids detected. Shifting to Fibonacci harmonics.")
    if frame == 199:
        print("Frame 200: Global Brain Sync Complete. Epsilon Soul Exported.")

